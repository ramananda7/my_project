<% layout("/layouts/boilerplate") %>
 <body>
    <h3>Listing Details :</h3>

    
    <ul>
      <li><%= kkk.description %></li>
      <li> &#8377; <%= kkk.price%></li>
      <li><%= kkk.location %></li>
      <li><%= kkk.country %></li>
    </ul>
  <% if(currUser && currUser._id.equals(kkk.Owner._id)) { %>
    <div class="btns" >
      <a href="/listings/<%= kkk.id %>/edit">Edit this Listing</a>
      <br /><br />
      <form method="POST" action="/listings/<%=kkk.id%>?_method=DELETE">
        <button>Delete this listing</button>
      </form>
    </div>
    <% } %>

